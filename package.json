{
  "name": "simmarket",
  "version": "1.0.5",
  "description": "Desktop app for monitoring SimCompanies market alerts locally.",
  "main": "src/main/main.js",
  "author": "Javi",
  "license": "UNLICENSED",
  "repository": {
    "type": "git",
    "url": "https://github.com/Vitosa0/simmarket.git"
  },
  "scripts": {
    "check": "node scripts/check-project.js",
    "start": "electron .",
    "icon:mac": "bash scripts/build-mac-icon.sh",
    "icon:win": "node scripts/build-win-icon.js",
    "dist": "npm run icon:mac && electron-builder --publish never",
    "dist:mac": "npm run icon:mac && electron-builder --mac dmg --universal --publish never",
    "dist:pkg": "npm run dist:mac && bash scripts/build-mac-installer.sh",
    "dist:win": "npm run icon:win && electron-builder --win nsis --x64 --publish never"
  },
  "devDependencies": {
    "electron": "^31.0.0",
    "electron-builder": "^24.13.3"
  },
  "dependencies": {
    "electron-updater": "^6.3.9"
  },
  "build": {
    "appId": "com.javi.simmarket",
    "productName": "SimMarket",
    "directories": {
      "output": "dist"
    },
    "files": [
      "src/**/*",
      "package.json"
    ],
    "asar": true,
    "mac": {
      "target": [
        {
          "target": "dmg",
          "arch": [
            "universal"
          ]
        }
      ],
      "icon": "build/SimMarket.icns",
      "category": "public.app-category.finance",
      "identity": null,
      "hardenedRuntime": false,
      "gatekeeperAssess": false
    },
    "win": {
      "target": [
        "nsis"
      ],
      "icon": "src/assets/branding/simmarket-mark.ico"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "allowElevation": true,
      "perMachine": false,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "SimMarket",
      "artifactName": "SimMarket-Installer-${version}-x64.${ext}",
      "deleteAppDataOnUninstall": true,
      "installerIcon": "src/assets/branding/simmarket-mark.ico",
      "uninstallerIcon": "src/assets/branding/simmarket-mark.ico",
      "installerHeaderIcon": "src/assets/branding/simmarket-mark.ico"
    },
    "publish": [
      {
        "provider": "github",
        "owner": "Vitosa0",
        "repo": "simmarket"
      }
    ]
  }
}
